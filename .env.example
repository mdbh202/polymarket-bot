GOOGLE_API_KEY=your_google_ai_studio_key_here
# Required for Gemini API access. Get from aistudio.google.com

GEMINI_MODEL=gemini-2.5-pro
# Optional model override. Options: gemini-2.5-pro, gemini-3.1-pro-preview,
# gemini-3.1-flash-lite-preview. Default: gemini-2.5-pro

POLYMARKET_API_KEY=
# Optional. For authenticated CLOB order reads above public rate limits.
# Get from polymarket.com/profile (API section)

POLYMARKET_PRIVATE_KEY=
# Optional. Polygon wallet private key for on-chain order signing.
# Never commit this value. Required only for live order execution.

NEWSDATA_API_KEY=
# Optional. For live news feed in news-server.js.
# Free tier at newsdata.io (200 requests/day)

PORTFOLIO_SIZE_USDC=1000
# Required for Kelly position sizing. Total portfolio in USDC.

MAX_SINGLE_POSITION_PCT=0.05
# Optional. Hard cap per position as fraction of portfolio. Default: 0.05 (5%)

MAX_CATEGORY_PCT=0.20
# Optional. Max exposure per event category. Default: 0.20 (20%)

MIN_EDGE_THRESHOLD=0.03
# Minimum after-fee edge to qualify a trade. Default: 0.03 (3%)

SCAN_INTERVAL_SECONDS=300
# Polling interval for watch.sh. Default: 300 (5 minutes)

OUTPUT_DIR=./output
# Directory for scan JSON output files.
